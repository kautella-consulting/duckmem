# DuckMem configuration example.
# Copy this file to `.env` and edit values to match your environment.
# All settings are optional and are also configurable in Python via `Settings(...)`.
# Every variable uses the DUCKMEM_ prefix.

# --- Database -----------------------------------------------------------------

# Path to the DuckDB database file (created on first use).
DUCKMEM_DB_PATH=./knowledge.duckdb

# --- Embeddings ---------------------------------------------------------------

# LiteLLM model string for the embedding model.
# Cloud example:  openai/text-embedding-3-small
# Local example:  ollama/qwen3-embedding:latest
DUCKMEM_EMBED_MODEL=openai/text-embedding-3-small

# Embedding vector dimension. MUST match the output size of DUCKMEM_EMBED_MODEL.
# openai/text-embedding-3-small => 1536
# ollama/qwen3-embedding:latest => 4096
DUCKMEM_EMBED_DIM=1536

# --- Chunking -----------------------------------------------------------------

# Text chunking strategy: "fixed" | "markdown" | "sentence"
DUCKMEM_CHUNK_STRATEGY=markdown

# Maximum characters per chunk.
DUCKMEM_CHUNK_MAX_CHARS=1000

# Character overlap between consecutive chunks.
DUCKMEM_CHUNK_OVERLAP=100

# Minimum characters for a chunk to be indexed.
DUCKMEM_CHUNK_MIN_CHARS=50

# --- LLM (RAG / extraction) ---------------------------------------------------

# LiteLLM model string for RAG answers and knowledge-graph extraction.
# Cloud example:  openai/gpt-4o-mini
# Local example:  ollama/gpt-oss:20b
DUCKMEM_LLM_MODEL=openai/gpt-4o-mini

# --- FastAPI server -----------------------------------------------------------

DUCKMEM_API_HOST=127.0.0.1
DUCKMEM_API_PORT=8000

# --- Search tuning ------------------------------------------------------------

# BM25 parameters (lexical search).
DUCKMEM_BM25_K1=1.2
DUCKMEM_BM25_B=0.75

# HNSW parameters (vector search).
DUCKMEM_HNSW_EF_SEARCH=64
DUCKMEM_HNSW_M=16

# Reciprocal Rank Fusion constant used to merge BM25 + vector results.
DUCKMEM_RRF_K=60

# --- Maintenance --------------------------------------------------------------

# Optional timeout (seconds) for `duckmem doctor` long-running ops. Unset = no timeout.
# DUCKMEM_DOCTOR_TIMEOUT_SECONDS=300
